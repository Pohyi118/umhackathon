# PeopleGraph Backend Environment Variables
# Copy this to .env and fill in actual values

# Application
APP_NAME=PeopleGraph
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# Database (PostgreSQL)
DATABASE_URL="postgresql+asyncpg://postgres.lxssmmqkjmpcxttvzela:umh2026@cgpt@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres"

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Malaysian Statutory Rates (update when legislation changes)
EPF_EMPLOYEE_RATE_BELOW_60=0.11
EPF_EMPLOYER_RATE_SALARY_LTE_5000=0.13
EPF_EMPLOYER_RATE_SALARY_GT_5000=0.12
SOCSO_EMPLOYER_RATE=0.0175
SOCSO_EMPLOYEE_RATE=0.005
SOCSO_SALARY_CAP=6000.0
EIS_RATE=0.002
EIS_SALARY_CAP=6000.0

# Neo4j (optional legacy)
# NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
# NEO4J_PASSWORD=your-neo4j-password

# ML Configuration
SENTIMENT_MODEL_NAME=cardiffnlp/twitter-xlm-roberta-base-sentiment
ANOMALY_CONTAMINATION=0.05
